{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=pixelrun.db"
  },
  "Jwt": {
    "Issuer": "PixelRunAPI",
    "Audience": "PixelRunGame",
    "Key": "${JWT_KEY}"
  },
  "AdminKey": "${ADMIN_KEY}",
  "Urls": "http://+:8080"
}